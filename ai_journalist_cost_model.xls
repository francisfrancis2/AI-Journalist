<?xml version="1.0"?>
<?mso-application progid="Excel.Sheet"?>
<Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet"
 xmlns:o="urn:schemas-microsoft-com:office:office"
 xmlns:x="urn:schemas-microsoft-com:office:excel"
 xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet"
 xmlns:html="http://www.w3.org/TR/REC-html40">
 <Styles>
  <Style ss:ID="Default" ss:Name="Normal">
   <Alignment ss:Vertical="Bottom"/>
   <Borders/>
   <Font ss:FontName="Calibri" ss:Size="11"/>
   <Interior/>
   <NumberFormat/>
   <Protection/>
  </Style>
  <Style ss:ID="title">
   <Font ss:FontName="Calibri" ss:Size="14" ss:Bold="1"/>
  </Style>
  <Style ss:ID="header">
   <Font ss:FontName="Calibri" ss:Size="11" ss:Bold="1"/>
   <Interior ss:Color="#DCE6F1" ss:Pattern="Solid"/>
  </Style>
  <Style ss:ID="label">
   <Font ss:FontName="Calibri" ss:Size="11" ss:Bold="1"/>
  </Style>
  <Style ss:ID="note">
   <Font ss:FontName="Calibri" ss:Size="11" ss:Italic="1"/>
  </Style>
  <Style ss:ID="currency">
   <NumberFormat ss:Format="Currency"/>
  </Style>
 </Styles>
 <Worksheet ss:Name="Summary"><Table><Row><Cell ss:StyleID="title"><Data ss:Type="String">AI Journalist Cost Model</Data></Cell></Row><Row><Cell ss:StyleID="note"><Data ss:Type="String">Generated workbook with per-script marginal cost plus monthly fixed-cost allocation.</Data></Cell></Row><Row></Row><Row><Cell ss:StyleID="header"><Data ss:Type="String">Metric</Data></Cell><Cell ss:StyleID="header"><Data ss:Type="String">Value</Data></Cell><Cell ss:StyleID="header"><Data ss:Type="String">Notes</Data></Cell></Row><Row><Cell ss:StyleID="label"><Data ss:Type="String">Marginal low cost per script</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.341612</Data></Cell><Cell><Data ss:Type="String">Third-party cost excluding fixed subscriptions</Data></Cell></Row><Row><Cell ss:StyleID="label"><Data ss:Type="String">Marginal typical cost per script</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.439105</Data></Cell><Cell><Data ss:Type="String">Third-party cost excluding fixed subscriptions</Data></Cell></Row><Row><Cell ss:StyleID="label"><Data ss:Type="String">Marginal high cost per script</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.813605</Data></Cell><Cell><Data ss:Type="String">Third-party cost excluding fixed subscriptions</Data></Cell></Row><Row><Cell ss:StyleID="label"><Data ss:Type="String">Monthly NewsAPI Business fee</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">449.0</Data></Cell><Cell><Data ss:Type="String">Allocate by scripts per month if used in production</Data></Cell></Row><Row><Cell ss:StyleID="label"><Data ss:Type="String">Monthly Alpha Vantage fee</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">49.99</Data></Cell><Cell><Data ss:Type="String">Allocate by scripts per month if premium plan is used</Data></Cell></Row><Row><Cell ss:StyleID="label"><Data ss:Type="String">Combined fixed monthly fee</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">498.99</Data></Cell><Cell><Data ss:Type="String">NewsAPI Business + Alpha Vantage premium</Data></Cell></Row><Row></Row><Row><Cell ss:StyleID="header"><Data ss:Type="String">Scripts per month</Data></Cell><Cell ss:StyleID="header"><Data ss:Type="String">Fixed cost / script</Data></Cell><Cell ss:StyleID="header"><Data ss:Type="String">Typical total / script</Data></Cell><Cell ss:StyleID="header"><Data ss:Type="String">Low total / script</Data></Cell><Cell ss:StyleID="header"><Data ss:Type="String">High total / script</Data></Cell></Row><Row><Cell><Data ss:Type="Number">100</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">4.9899000000000004</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">5.429005</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">5.331512</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">5.803505</Data></Cell></Row><Row><Cell><Data ss:Type="Number">250</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">1.99596</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">2.435065</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">2.3375719999999998</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">2.809565</Data></Cell></Row><Row><Cell><Data ss:Type="Number">500</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.99798</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">1.437085</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">1.3395920000000001</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">1.811585</Data></Cell></Row><Row><Cell><Data ss:Type="Number">1000</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.49899</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.938095</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.8406020000000001</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">1.312595</Data></Cell></Row><Row><Cell><Data ss:Type="Number">5000</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.099798</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.538903</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.44141</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.913403</Data></Cell></Row></Table></Worksheet><Worksheet ss:Name="Per Script Model"><Table><Row><Cell ss:StyleID="header"><Data ss:Type="String">category</Data></Cell><Cell ss:StyleID="header"><Data ss:Type="String">service</Data></Cell><Cell ss:StyleID="header"><Data ss:Type="String">metric</Data></Cell><Cell ss:StyleID="header"><Data ss:Type="String">unit_price_usd</Data></Cell><Cell ss:StyleID="header"><Data ss:Type="String">usage_low</Data></Cell><Cell ss:StyleID="header"><Data ss:Type="String">usage_typical</Data></Cell><Cell ss:StyleID="header"><Data ss:Type="String">usage_high</Data></Cell><Cell ss:StyleID="header"><Data ss:Type="String">cost_low_usd</Data></Cell><Cell ss:StyleID="header"><Data ss:Type="String">cost_typical_usd</Data></Cell><Cell ss:StyleID="header"><Data ss:Type="String">cost_high_usd</Data></Cell><Cell ss:StyleID="header"><Data ss:Type="String">formula</Data></Cell><Cell ss:StyleID="header"><Data ss:Type="String">notes</Data></Cell></Row><Row><Cell><Data ss:Type="String">llm</Data></Cell><Cell><Data ss:Type="String">Anthropic Claude Opus 4.6</Data></Cell><Cell><Data ss:Type="String">input_tokens_per_million</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">5.0</Data></Cell><Cell><Data ss:Type="Number">16500.0</Data></Cell><Cell><Data ss:Type="Number">24000.0</Data></Cell><Cell><Data ss:Type="Number">53000.0</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.0825</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.12</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.265</Data></Cell><Cell><Data ss:Type="String">usage/1000000*unit_price</Data></Cell><Cell><Data ss:Type="String">Uses current Opus 4.6 pricing from product page</Data></Cell></Row><Row><Cell><Data ss:Type="String">llm</Data></Cell><Cell><Data ss:Type="String">Anthropic Claude Opus 4.6</Data></Cell><Cell><Data ss:Type="String">output_tokens_per_million</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">25.0</Data></Cell><Cell><Data ss:Type="Number">5100.0</Data></Cell><Cell><Data ss:Type="Number">7500.0</Data></Cell><Cell><Data ss:Type="Number">15400.0</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.1275</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.1875</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.385</Data></Cell><Cell><Data ss:Type="String">usage/1000000*unit_price</Data></Cell><Cell><Data ss:Type="String">Uses current Opus 4.6 pricing from product page</Data></Cell></Row><Row><Cell><Data ss:Type="String">search</Data></Cell><Cell><Data ss:Type="String">Tavily</Data></Cell><Cell><Data ss:Type="String">api_credit</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.008</Data></Cell><Cell><Data ss:Type="Number">16.0</Data></Cell><Cell><Data ss:Type="Number">16.0</Data></Cell><Cell><Data ss:Type="Number">20.0</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.128</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.128</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.16</Data></Cell><Cell><Data ss:Type="String">usage*unit_price</Data></Cell><Cell><Data ss:Type="String">Current code uses advanced search depth so each search costs 2 credits</Data></Cell></Row><Row><Cell><Data ss:Type="String">search</Data></Cell><Cell><Data ss:Type="String">Tavily monthly plan</Data></Cell><Cell><Data ss:Type="String">base_fee_per_script_formula</Data></Cell><Cell><Data ss:Type="String"></Data></Cell><Cell><Data ss:Type="Number">1.0</Data></Cell><Cell><Data ss:Type="Number">1.0</Data></Cell><Cell><Data ss:Type="Number">1.0</Data></Cell><Cell><Data ss:Type="String"></Data></Cell><Cell><Data ss:Type="String"></Data></Cell><Cell><Data ss:Type="String"></Data></Cell><Cell><Data ss:Type="String">monthly_fee/scripts_per_month</Data></Cell><Cell><Data ss:Type="String">If you use a monthly Tavily plan instead of pay-as-you-go allocate the subscription across scripts</Data></Cell></Row><Row><Cell><Data ss:Type="String">news</Data></Cell><Cell><Data ss:Type="String">NewsAPI</Data></Cell><Cell><Data ss:Type="String">request_overage_business_plan</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.0018</Data></Cell><Cell><Data ss:Type="Number">2.0</Data></Cell><Cell><Data ss:Type="Number">2.0</Data></Cell><Cell><Data ss:Type="Number">2.0</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.0036</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.0036</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.0036</Data></Cell><Cell><Data ss:Type="String">usage*unit_price</Data></Cell><Cell><Data ss:Type="String">Business plan overage rate only; base subscription not allocated here</Data></Cell></Row><Row><Cell><Data ss:Type="String">news</Data></Cell><Cell><Data ss:Type="String">NewsAPI</Data></Cell><Cell><Data ss:Type="String">request_overage_advanced_plan</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.0009</Data></Cell><Cell><Data ss:Type="Number">2.0</Data></Cell><Cell><Data ss:Type="Number">2.0</Data></Cell><Cell><Data ss:Type="Number">2.0</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.0018</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.0018</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.0018</Data></Cell><Cell><Data ss:Type="String">usage*unit_price</Data></Cell><Cell><Data ss:Type="String">Advanced plan overage rate only; base subscription not allocated here</Data></Cell></Row><Row><Cell><Data ss:Type="String">news</Data></Cell><Cell><Data ss:Type="String">NewsAPI Business</Data></Cell><Cell><Data ss:Type="String">base_fee_per_script_formula</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">449.0</Data></Cell><Cell><Data ss:Type="Number">1.0</Data></Cell><Cell><Data ss:Type="Number">1.0</Data></Cell><Cell><Data ss:Type="Number">1.0</Data></Cell><Cell><Data ss:Type="String"></Data></Cell><Cell><Data ss:Type="String"></Data></Cell><Cell><Data ss:Type="String"></Data></Cell><Cell><Data ss:Type="String">449/scripts_per_month</Data></Cell><Cell><Data ss:Type="String">Allocate only if this app is using the Business plan in production</Data></Cell></Row><Row><Cell><Data ss:Type="String">news</Data></Cell><Cell><Data ss:Type="String">NewsAPI Advanced</Data></Cell><Cell><Data ss:Type="String">base_fee_per_script_formula</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">1749.0</Data></Cell><Cell><Data ss:Type="Number">1.0</Data></Cell><Cell><Data ss:Type="Number">1.0</Data></Cell><Cell><Data ss:Type="Number">1.0</Data></Cell><Cell><Data ss:Type="String"></Data></Cell><Cell><Data ss:Type="String"></Data></Cell><Cell><Data ss:Type="String"></Data></Cell><Cell><Data ss:Type="String">1749/scripts_per_month</Data></Cell><Cell><Data ss:Type="String">Allocate only if this app is using the Advanced plan in production</Data></Cell></Row><Row><Cell><Data ss:Type="String">finance</Data></Cell><Cell><Data ss:Type="String">Alpha Vantage premium 75 rpm</Data></Cell><Cell><Data ss:Type="String">base_fee_per_script_formula</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">49.99</Data></Cell><Cell><Data ss:Type="Number">1.0</Data></Cell><Cell><Data ss:Type="Number">1.0</Data></Cell><Cell><Data ss:Type="Number">1.0</Data></Cell><Cell><Data ss:Type="String"></Data></Cell><Cell><Data ss:Type="String"></Data></Cell><Cell><Data ss:Type="String"></Data></Cell><Cell><Data ss:Type="String">49.99/scripts_per_month</Data></Cell><Cell><Data ss:Type="String">Best treated as a fixed monthly subscription instead of per-request overage</Data></Cell></Row><Row><Cell><Data ss:Type="String">rss</Data></Cell><Cell><Data ss:Type="String">RSS feeds</Data></Cell><Cell><Data ss:Type="String">request</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.0</Data></Cell><Cell><Data ss:Type="Number">9.0</Data></Cell><Cell><Data ss:Type="Number">9.0</Data></Cell><Cell><Data ss:Type="Number">9.0</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.0</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.0</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.0</Data></Cell><Cell><Data ss:Type="String">usage*unit_price</Data></Cell><Cell><Data ss:Type="String">RSS feed polling has no direct vendor fee in current setup</Data></Cell></Row><Row><Cell><Data ss:Type="String">scraping</Data></Cell><Cell><Data ss:Type="String">Playwright</Data></Cell><Cell><Data ss:Type="String">browser_scrape_vendor_cost</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.0</Data></Cell><Cell><Data ss:Type="Number">5.0</Data></Cell><Cell><Data ss:Type="Number">5.0</Data></Cell><Cell><Data ss:Type="Number">5.0</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.0</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.0</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.0</Data></Cell><Cell><Data ss:Type="String">usage*unit_price</Data></Cell><Cell><Data ss:Type="String">No direct third-party per-scrape fee; compute cost is separate</Data></Cell></Row><Row><Cell><Data ss:Type="String">storage</Data></Cell><Cell><Data ss:Type="String">AWS S3 Standard</Data></Cell><Cell><Data ss:Type="String">put_request</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">5e-06</Data></Cell><Cell><Data ss:Type="Number">1.0</Data></Cell><Cell><Data ss:Type="Number">1.0</Data></Cell><Cell><Data ss:Type="Number">1.0</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">5e-06</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">5e-06</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">5e-06</Data></Cell><Cell><Data ss:Type="String">usage*unit_price</Data></Cell><Cell><Data ss:Type="String">Derived from 0.005 per 1000 PUT requests</Data></Cell></Row><Row><Cell><Data ss:Type="String">storage</Data></Cell><Cell><Data ss:Type="String">AWS S3 Standard</Data></Cell><Cell><Data ss:Type="String">storage_gb_month</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.023</Data></Cell><Cell><Data ss:Type="Number">0.0003</Data></Cell><Cell><Data ss:Type="Number">0.0003</Data></Cell><Cell><Data ss:Type="Number">0.0003</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">7e-06</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">7e-06</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">7e-06</Data></Cell><Cell><Data ss:Type="String">usage*unit_price</Data></Cell><Cell><Data ss:Type="String">Assumes one 300 KB JSON script stored for one month</Data></Cell></Row><Row><Cell><Data ss:Type="String">summary</Data></Cell><Cell><Data ss:Type="String">Third-party marginal cash cost excluding fixed subscriptions</Data></Cell><Cell><Data ss:Type="String">total</Data></Cell><Cell><Data ss:Type="String"></Data></Cell><Cell><Data ss:Type="Number">0.0</Data></Cell><Cell><Data ss:Type="Number">0.0</Data></Cell><Cell><Data ss:Type="Number">0.0</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.341612</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.439105</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.813605</Data></Cell><Cell><Data ss:Type="String">sum(selected rows except alternative NewsAPI lines)</Data></Cell><Cell><Data ss:Type="String">Includes Anthropic Opus 4.6 plus Tavily plus S3 plus NewsAPI Business overage</Data></Cell></Row><Row><Cell><Data ss:Type="String">summary</Data></Cell><Cell><Data ss:Type="String">Third-party marginal cash cost excluding fixed subscriptions total with NewsAPI advanced overage</Data></Cell><Cell><Data ss:Type="String">total</Data></Cell><Cell><Data ss:Type="String"></Data></Cell><Cell><Data ss:Type="Number">0.0</Data></Cell><Cell><Data ss:Type="Number">0.0</Data></Cell><Cell><Data ss:Type="Number">0.0</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.339812</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.437305</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.811805</Data></Cell><Cell><Data ss:Type="String">sum(selected rows except alternative NewsAPI lines)</Data></Cell><Cell><Data ss:Type="String">Same as above but using NewsAPI Advanced overage rate</Data></Cell></Row></Table></Worksheet><Worksheet ss:Name="Volume Scenarios"><Table><Row><Cell ss:StyleID="title"><Data ss:Type="String">Volume Scenario Model</Data></Cell></Row><Row></Row><Row><Cell ss:StyleID="header"><Data ss:Type="String">Scripts / Month</Data></Cell><Cell ss:StyleID="header"><Data ss:Type="String">Fixed Monthly Cost</Data></Cell><Cell ss:StyleID="header"><Data ss:Type="String">Fixed Cost / Script</Data></Cell><Cell ss:StyleID="header"><Data ss:Type="String">Marginal Typical / Script</Data></Cell><Cell ss:StyleID="header"><Data ss:Type="String">Total Typical / Script</Data></Cell><Cell ss:StyleID="header"><Data ss:Type="String">Total Monthly Spend Typical</Data></Cell></Row><Row><Cell><Data ss:Type="Number">100</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">498.99</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">4.9899000000000004</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.439105</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">5.429005</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">542.9005</Data></Cell></Row><Row><Cell><Data ss:Type="Number">250</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">498.99</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">1.99596</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.439105</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">2.435065</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">608.76625</Data></Cell></Row><Row><Cell><Data ss:Type="Number">500</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">498.99</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.99798</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.439105</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">1.437085</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">718.5425</Data></Cell></Row><Row><Cell><Data ss:Type="Number">1000</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">498.99</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.49899</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.439105</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.938095</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">938.095</Data></Cell></Row><Row><Cell><Data ss:Type="Number">5000</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">498.99</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.099798</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.439105</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">0.538903</Data></Cell><Cell ss:StyleID="currency"><Data ss:Type="Number">2694.5150000000003</Data></Cell></Row></Table></Worksheet><Worksheet ss:Name="Assumptions"><Table><Row><Cell ss:StyleID="title"><Data ss:Type="String">Assumptions</Data></Cell></Row><Row><Cell><Data ss:Type="String"># Per-Script Cost Model Assumptions</Data></Cell></Row><Row><Cell><Data ss:Type="String"></Data></Cell></Row><Row><Cell><Data ss:Type="String">This model is based on the current application code in `backend/agents/` and `backend/tools/`.</Data></Cell></Row><Row><Cell><Data ss:Type="String"></Data></Cell></Row><Row><Cell><Data ss:Type="String">## Pipeline assumptions</Data></Cell></Row><Row><Cell><Data ss:Type="String"></Data></Cell></Row><Row><Cell><Data ss:Type="String">- One completed script normally triggers:</Data></Cell></Row><Row><Cell><Data ss:Type="String">- 1 Anthropic call in `ResearcherAgent` for query planning</Data></Cell></Row><Row><Cell><Data ss:Type="String">- 1 Anthropic call in `AnalystAgent`</Data></Cell></Row><Row><Cell><Data ss:Type="String">- 1 Anthropic call in `StorylineCreatorAgent`</Data></Cell></Row><Row><Cell><Data ss:Type="String">- 1 Anthropic call in `EvaluatorAgent`</Data></Cell></Row><Row><Cell><Data ss:Type="String">- 3 to 6 Anthropic calls in `ScriptwriterAgent`, depending on number of acts</Data></Cell></Row><Row><Cell><Data ss:Type="String"></Data></Cell></Row><Row><Cell><Data ss:Type="String">## Search and data-source assumptions</Data></Cell></Row><Row><Cell><Data ss:Type="String"></Data></Cell></Row><Row><Cell><Data ss:Type="String">- Tavily:</Data></Cell></Row><Row><Cell><Data ss:Type="String">- Current code uses `search_depth="advanced"` in config</Data></Cell></Row><Row><Cell><Data ss:Type="String">- Typical story assumes 8 searches total</Data></Cell></Row><Row><Cell><Data ss:Type="String">- At advanced depth, each search costs 2 Tavily credits</Data></Cell></Row><Row><Cell><Data ss:Type="String"></Data></Cell></Row><Row><Cell><Data ss:Type="String">- NewsAPI:</Data></Cell></Row><Row><Cell><Data ss:Type="String">- Current code searches the first 2 primary queries only</Data></Cell></Row><Row><Cell><Data ss:Type="String">- Typical story assumes 2 NewsAPI requests</Data></Cell></Row><Row><Cell><Data ss:Type="String">- The CSV uses overage pricing only, not a share of the monthly base subscription</Data></Cell></Row><Row><Cell><Data ss:Type="String"></Data></Cell></Row><Row><Cell><Data ss:Type="String">- Alpha Vantage:</Data></Cell></Row><Row><Cell><Data ss:Type="String">- Current code may call up to 2 endpoints per symbol:</Data></Cell></Row><Row><Cell><Data ss:Type="String">- `get_company_overview`</Data></Cell></Row><Row><Cell><Data ss:Type="String">- `get_daily_prices`</Data></Cell></Row><Row><Cell><Data ss:Type="String">- Typical story assumes 1 symbol = 2 calls</Data></Cell></Row><Row><Cell><Data ss:Type="String">- High story assumes 3 symbols = 6 calls</Data></Cell></Row><Row><Cell><Data ss:Type="String">- Alpha Vantage pricing is better treated as a monthly fixed cost:</Data></Cell></Row><Row><Cell><Data ss:Type="String">- `$49.99/month` for the smallest listed premium plan</Data></Cell></Row><Row><Cell><Data ss:Type="String">- The CSV therefore models Alpha Vantage as `49.99 / scripts_per_month`</Data></Cell></Row><Row><Cell><Data ss:Type="String">- This avoids inventing a request-level overage price that Alpha Vantage does not publish</Data></Cell></Row><Row><Cell><Data ss:Type="String"></Data></Cell></Row><Row><Cell><Data ss:Type="String">## Storage assumptions</Data></Cell></Row><Row><Cell><Data ss:Type="String"></Data></Cell></Row><Row><Cell><Data ss:Type="String">- S3:</Data></Cell></Row><Row><Cell><Data ss:Type="String">- 1 JSON upload per completed story</Data></Cell></Row><Row><Cell><Data ss:Type="String">- 300 KB object retained for 1 month</Data></Cell></Row><Row><Cell><Data ss:Type="String">- No meaningful data transfer cost at this size</Data></Cell></Row><Row><Cell><Data ss:Type="String"></Data></Cell></Row><Row><Cell><Data ss:Type="String">## Pricing sources used</Data></Cell></Row><Row><Cell><Data ss:Type="String"></Data></Cell></Row><Row><Cell><Data ss:Type="String">- Anthropic pricing:</Data></Cell></Row><Row><Cell><Data ss:Type="String">- https://docs.anthropic.com/en/docs/about-claude/pricing</Data></Cell></Row><Row><Cell><Data ss:Type="String"></Data></Cell></Row><Row><Cell><Data ss:Type="String">- Tavily pricing and credits:</Data></Cell></Row><Row><Cell><Data ss:Type="String">- https://docs.tavily.com/guides/api-credits</Data></Cell></Row><Row><Cell><Data ss:Type="String"></Data></Cell></Row><Row><Cell><Data ss:Type="String">- NewsAPI pricing:</Data></Cell></Row><Row><Cell><Data ss:Type="String">- https://newsapi.org/pricing</Data></Cell></Row><Row><Cell><Data ss:Type="String"></Data></Cell></Row><Row><Cell><Data ss:Type="String">- Alpha Vantage premium pricing:</Data></Cell></Row><Row><Cell><Data ss:Type="String">- https://www.alphavantage.co/premium/</Data></Cell></Row><Row><Cell><Data ss:Type="String"></Data></Cell></Row><Row><Cell><Data ss:Type="String">- AWS S3 pricing:</Data></Cell></Row><Row><Cell><Data ss:Type="String">- https://aws.amazon.com/s3/pricing/</Data></Cell></Row><Row><Cell><Data ss:Type="String"></Data></Cell></Row><Row><Cell><Data ss:Type="String">## Important caveat</Data></Cell></Row><Row><Cell><Data ss:Type="String"></Data></Cell></Row><Row><Cell><Data ss:Type="String">This model is a cash-cost estimate per completed script, not full profitability accounting.</Data></Cell></Row><Row><Cell><Data ss:Type="String"></Data></Cell></Row><Row><Cell><Data ss:Type="String">It does not include:</Data></Cell></Row><Row><Cell><Data ss:Type="String"></Data></Cell></Row><Row><Cell><Data ss:Type="String">- engineering time</Data></Cell></Row><Row><Cell><Data ss:Type="String">- hosting for FastAPI / Next.js / database</Data></Cell></Row><Row><Cell><Data ss:Type="String">- CPU or RAM consumed by Playwright scrapes</Data></Cell></Row><Row><Cell><Data ss:Type="String">- networking</Data></Cell></Row><Row><Cell><Data ss:Type="String">- observability</Data></Cell></Row><Row><Cell><Data ss:Type="String">- retries due to failures</Data></Cell></Row><Row><Cell><Data ss:Type="String">- unused monthly subscription minimums</Data></Cell></Row><Row><Cell><Data ss:Type="String"></Data></Cell></Row><Row><Cell><Data ss:Type="String">If you want a fully loaded unit economics model next, add fixed monthly costs and divide by expected scripts per month.</Data></Cell></Row></Table></Worksheet>
</Workbook>
