# ─────────────────────────────────────────────────────────────────────────────
# AI Journalist — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Tavily (web search) ───────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...

# ── NewsAPI ───────────────────────────────────────────────────────────────────
NEWS_API_KEY=...
RSS_FETCH_TIMEOUT_SECONDS=8

# ── Alpha Vantage (financial data) ────────────────────────────────────────────
ALPHA_VANTAGE_API_KEY=...

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://aijournalist:secret@localhost:5432/aijournalist
RUN_MIGRATIONS_ON_STARTUP=true
DB_POOL_RECYCLE_SECONDS=300

# ── AWS / S3 ──────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
S3_BUCKET_SCRIPTS=ai-journalist-scripts
S3_BUCKET_ASSETS=ai-journalist-assets

# ── YouTube Data API ──────────────────────────────────────────────────────────
YOUTUBE_API_KEY=your-youtube-data-api-v3-key
BENCHMARK_SEED_ON_STARTUP=false

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=generate-a-strong-random-secret-here
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-temporary-password

# ── Application ───────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO

# ── Frontend ──────────────────────────────────────────────────────────────────
# Leave empty to use Next.js rewrites/proxy. Set only when the browser should
# call a backend URL directly.
NEXT_PUBLIC_API_URL=
